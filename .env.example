# Paths (relative to project root)
TAXONOMY_CSV=taxonomy_full.csv
DATA_DIR=data
MODELS_DIR=models

# Training
BATCH_SIZE=32
MAX_EPOCHS=5
EARLY_STOPPING_PATIENCE=3
MAX_TOKEN_LENGTH=128
LEARNING_RATE=2e-5
DROPOUT=0.1

# Confidence thresholds (inference)
SUPER_CONFIDENCE_THRESHOLD=0.50
PARENT_CONFIDENCE_THRESHOLD=0.60
LEAF_CONFIDENCE_THRESHOLD=0.75
