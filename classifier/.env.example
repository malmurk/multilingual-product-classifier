# ---- Shop DB (required for the worker) ----
# Live marketplace MariaDB:
DB_URL=mysql+pymysql://user:pass@db-host:3306/catalog_db?charset=utf8mb4

# How often (seconds) the worker reloads the categories.name -> id map.
RESOLVER_REFRESH_SECONDS=3600

# ---- Auto-assign threshold ----
# Leaf confidence >= this -> products.category_id is set automatically.
# Below -> the row is sent to the manual_sorting queue for a human reviewer.
THRESHOLD_LEAF_AUTO=0.93

# ---- Predictor stage thresholds ----
# Kept low so the predictor always emits a leaf-level guess for the
# human reviewer to see.  The auto/manual decision is driven by
# THRESHOLD_LEAF_AUTO above, not by these.
THRESHOLD_SUPER=0.50
THRESHOLD_PARENT=0.50
THRESHOLD_LEAF=0.50

# ---- Worker ----
BATCH_SIZE=100
POLL_INTERVAL=1800
CORRECTIONS_PATH=/app/data/corrections.jsonl

# ---- Misc ----
LOG_LEVEL=INFO
MODEL_DIR=/app/models
TOKENIZER=xlm-roberta-base
